		"@types/react": "^19.2.9",
		"@types/shell-quote": "^1.7.5",
		"@types/should": "^11.2.0",
		"@types/sinon": "^17.0.4",
		"@types/turndown": "^5.0.5",
		"c8": "^10.1.3",
		"chai": "^4.3.10",
		"chalk": "5.6.2",
		"cross-env": "^10.1.0",
		"dotenv": "^17.2.3",
		"esbuild": "^0.25.0",
		"husky": "^9.1.7",
		"ink-testing-library": "^4.0.0",
		"lint-staged": "^16.1.0",
		"minimatch": "^3.0.3",
		"npm-run-all": "^4.1.5",
		"nyc": "^17.1.0",
