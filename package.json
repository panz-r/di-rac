	"c8": {
		"reporter": [
			"lcov",
			"html"
		],
		"exclude": [
			"**/testing-platform/**",
			"**/webview-ui/**",
			"**/node_modules/**",
			"node_modules",
			"**/dist-standalone/src/**",
			"**/dist-standalone/vsce-extension/https:/**",
			"**/dist-standalone/vsce-extension/**",
			"**/dist-standalone/https:/**",
			"**/dist-standalone/LIB/src/**",
			"**/dist-standalone/pdfjs-dist/**",
			"**/*.d.ts",
