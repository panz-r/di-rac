# ── Large Hook Limit ─────────────────────────────────────────────
# Intent: Verify that the evaluator caps the number of actions
#          per event (max_actions_per_event = 20 by default).
#          This handler emits 16 warn() calls; the cap ensures
#          no single event handler can produce unbounded output.
# Events: post_tool_use
# Groups: none
# Roles: none
# Actions: warn
# Variants: N/A — adversarial/correctness test
# Note: This is a system-verification hook, not a production pattern.
# ───────────────────────────────────────────────────────────────────
@on("post_tool_use")
def too_many_actions():
    warn(severity="info", message="1")
    warn(severity="info", message="2")
    warn(severity="info", message="3")
    warn(severity="info", message="4")
    warn(severity="info", message="5")
    warn(severity="info", message="6")
    warn(severity="info", message="7")
    warn(severity="info", message="8")
    warn(severity="info", message="9")
    warn(severity="info", message="10")
    warn(severity="info", message="11")
    warn(severity="info", message="12")
    warn(severity="info", message="13")
    warn(severity="info", message="14")
    warn(severity="info", message="15")
    warn(severity="info", message="16")
